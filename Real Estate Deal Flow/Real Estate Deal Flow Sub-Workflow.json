      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this title document:\n\n{{ $json.data }}",
        "options": {
          "systemMessage": "You are a Nigerian real estate legal document analyst with expertise in Lagos State property law.\n\nAnalyze the following document text extracted from a title document and determine:\n\n1. **Document Type**: C of O, Governor's Consent, Survey Plan, Excision, Deed of Assignment, etc.\n2. **Authenticity Assessment**: Based on formatting, language, and content, rate authenticity 1-10\n3. **Key Details**: Property location, registered owner, date of issue, plot size, survey plan number\n4. **Red Flags**: Expired documents, inconsistent dates, missing signatures, forged indicators, mismatch with listing details\n5. **Location Cross-check**: Does the document location match the property listing location?\n\nRespond ONLY as valid JSON:\n{\"doc_type\": \"...\", \"authenticity_score\": <1-10>, \"key_details\": {\"owner\": \"...\", \"location\": \"...\", \"date_issued\": \"...\", \"plot_size\": \"...\"}, \"red_flags\": [\"...\"], \"recommendation\": \"<VERIFIED|CAUTION|REJECT>\", \"summary\": \"<2-3 sentence analysis>\"}",
          "maxIterations": 1
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        4720,
        2016
      ],
      "name": "AI Document Analyst",
      "id": "aa9e721a-ab4d-4611-aabf-099286d82f87"
    },
    {
      "parameters": {
        "jsCode": "const email = $input.first().json;\nreturn [{\n  json: {\n    note: 'Broker replied without documents',\n    from: email.from || 'Unknown',\n    subject: email.subject || '',\n    body_preview: (email.text || email.html || '').substring(0, 500)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4272,
        2208
      ],
      "name": "Log Reply Without Documents",
      "id": "0fa9da2e-181f-42de-8774-0cd35fd97b85"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const aiOutput = $input.item.json;\nlet result = {};\ntry {\n  const text = aiOutput.output || aiOutput.text || '{}';\n  const jsonMatch = text.match(/\\{[\\s\\S]*\\}/);\n  result = jsonMatch ? JSON.parse(jsonMatch[0]) : {};\n} catch (e) {\n  result = { doc_type: 'Unknown', authenticity_score: 0, recommendation: 'REJECT', summary: 'Failed to parse' };\n}\n\nlet emailFrom = 'unknown@example.com';\nlet emailSubject = '';\nlet propertyTitle = '';\n\ntry {\n  const index = $itemIndex;\n  const allLoopItems = $('Loop Over All Attachments').all();\n  const targetItem = allLoopItems[index] || allLoopItems[0];\n  if (targetItem && targetItem.json) {\n    const fromField = targetItem.json.from;\n    if (fromField && typeof fromField === 'object' && fromField.value && fromField.value[0]) {\n      emailFrom = (fromField.value[0].address || '').toLowerCase();\n    } else {\n      const rawFrom = String(fromField || '');\n      const emailMatch = rawFrom.match(/[\\w.+-]+@[\\w-]+\\.[\\w.]+/);\n      emailFrom = emailMatch ? emailMatch[0].toLowerCase() : rawFrom.toLowerCase();\n    }\n    emailSubject = String(targetItem.json.subject || '');\n    propertyTitle = emailSubject.replace(/^Re:\\s*/i, '').trim();\n  }\n} catch (e) {}\n\nreturn {\n  json: {\n    email_from: emailFrom,\n    email_subject: emailSubject,\n    property_title: propertyTitle,\n    doc_type: result.doc_type || 'Unknown',\n    authenticity_score: result.authenticity_score || 0,\n    doc_recommendation: result.recommendation || 'REJECT',\n    summary: result.summary || 'No analysis',\n    red_flags: (result.red_flags || []).join(', '),\n    owner: (result.key_details || {}).owner || '',\n    doc_location: (result.key_details || {}).location || '',\n    date_issued: (result.key_details || {}).date_issued || ''\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5072,
        2016
      ],
      "name": "Parse Document Verification Result",
      "id": "dd65e930-2ab4-4da6-935c-ece256950481"
    },
    {
      "parameters": {
        "operation": "search",
        "base": {
          "__rl": true,
          "value": "appXpYbJyZfucB4tT",
          "mode": "list",
          "cachedResultName": "Real Estate Dealflow"
        },
        "table": {
          "__rl": true,
          "value": "tblBdcnelAQov15Xw",
          "mode": "list",
          "cachedResultName": "Investment Criteria"
        },
        "filterByFormula": "=AND(LOWER({Agent_Email}) = LOWER('{{ $json.email_from }}'), OR({Outreach_Status} = \"Sent\", {Outreach_Status} = \"\"))",
        "options": {
          "fields": [
