      "parameters": {
        "jsCode": "const binaryKeys = Object.keys($binary || {});\nreturn binaryKeys.map(key => ({\n  json: { ...$json, attachmentKey: key },\n  binary: { [key]: $binary[key] }\n}));"
      },
