    {
      "parameters": {
        "jsCode": "const analyses = $('Parse Document Verification Result').all().map(a => a.json);\nconst airtableRecords = $input.all().map(a => a.json);\n\nconst results = [];\nconst usedRecordIds = new Set();\n\nfor (const analysis of analyses) {\n  const potentialRecords = airtableRecords.filter(r =>\n    (r.Agent_Email || '').toLowerCase() === (analysis.email_from || '').toLowerCase()\n  );\n\n  let bestRecord = null;\n\n  for (const r of potentialRecords) {\n    if (usedRecordIds.has(r.id)) continue;\n    const titleLower = (r.Title || '').toLowerCase();\n    const subjectLower = (analysis.email_subject || '').toLowerCase();\n    const propTitleLower = (analysis.property_title || '').toLowerCase();\n    if (titleLower && (subjectLower.includes(titleLower) || titleLower.includes(propTitleLower))) {\n      bestRecord = r;\n      break;\n    }\n  }\n\n  if (!bestRecord) {\n    bestRecord = potentialRecords.find(r => !usedRecordIds.has(r.id));\n  }\n\n  if (bestRecord) {\n    usedRecordIds.add(bestRecord.id);\n    results.push({ json: { id: bestRecord.id, ...analysis } });\n  }\n}\n\nreturn results;"
      },
