    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const aiOutput = $input.item.json;\nlet result = {};\ntry {\n  const text = aiOutput.output || aiOutput.text || '{}';\n  const jsonMatch = text.match(/\\{[\\s\\S]*\\}/);\n  result = jsonMatch ? JSON.parse(jsonMatch[0]) : {};\n} catch (e) {\n  result = { doc_type: 'Unknown', authenticity_score: 0, recommendation: 'REJECT', summary: 'Failed to parse' };\n}\n\nlet emailFrom = 'unknown@example.com';\nlet emailSubject = '';\nlet propertyTitle = '';\nlet attachmentKey = '';\nlet outputBinary = {};\n\ntry {\n  const index = $itemIndex;\n  const allLoopItems = $('Loop Over All Attachments').all();\n  const targetItem = allLoopItems[index] || allLoopItems[0];\n\n  if (targetItem && targetItem.json) {\n    const fromField = targetItem.json.from;\n    if (fromField && typeof fromField === 'object' && fromField.value && fromField.value[0]) {\n      emailFrom = (fromField.value[0].address || '').toLowerCase();\n    } else {\n      const rawFrom = String(fromField || '');\n      const emailMatch = rawFrom.match(/[\\w.+-]+@[\\w-]+\\.[\\w.]+/);\n      emailFrom = emailMatch ? emailMatch[0].toLowerCase() : rawFrom.toLowerCase();\n    }\n    emailSubject = String(targetItem.json.subject || '');\n    propertyTitle = emailSubject.replace(/^Re:\\s*/i, '').trim();\n    attachmentKey = targetItem.json.attachmentKey || Object.keys(targetItem.binary || {})[0] || '';\n\n    if (attachmentKey && targetItem.binary?.[attachmentKey]) {\n      outputBinary = {\n        [attachmentKey]: targetItem.binary[attachmentKey]\n      };\n    } else {\n      outputBinary = targetItem.binary || {};\n    }\n  }\n} catch (e) {}\n\nreturn {\n  json: {\n    email_from: emailFrom,\n    email_subject: emailSubject,\n    property_title: propertyTitle,\n    attachmentKey,\n    doc_type: result.doc_type || 'Unknown',\n    authenticity_score: result.authenticity_score || 0,\n    doc_recommendation: result.recommendation || 'REJECT',\n    summary: result.summary || 'No analysis',\n    red_flags: (result.red_flags || []).join(', '),\n    owner: (result.key_details || {}).owner || '',\n    doc_location: (result.key_details || {}).location || '',\n    date_issued: (result.key_details || {}).date_issued || ''\n  },\n  binary: outputBinary\n};"
      },
