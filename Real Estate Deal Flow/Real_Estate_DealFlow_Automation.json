    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data || '';\nconst listing = $('Loop Over Listings').first().json;\nconst scrape = (r) => (html.match(r) || [])[1] || '';\n\nlet rawDesc = '';\nconst descBlock = html.match(/<h2>\\s*Description\\s*<\\/h2>\\s*<div[^>]*class=\"des-inner[^\"]*\">([\\s\\S]*?)<div>\\s*<\\/div>/i);\nif (descBlock) {\n  rawDesc = descBlock[1];\n} else {\n  rawDesc = scrape(/property=\"og:description\"[^>]*content=\"([^\"]+)\"/);\n}\n\n// Clean and format description\nlet description = rawDesc\n  .replace(/<br\\s*\\/?>/gi, '\\n')\n  .replace(/<[^>]+>/g, '')\n  .replace(/&amp;/g, '&')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&quot;/g, '\"')\n  .replace(/&#39;/g, \"'\")\n  .replace(/\\*+/g, '')\n  .trim();\n\n\ndescription = description.replace(/ - (?=[A-Z0-9])/g, '\\n- ');\n\n// Format section headers on their own lines\ndescription = description\n  .replace(/Key Features:\\s*/i, '\\n\\nKey Features:\\n')\n  .replace(/Features:\\s*/i, '\\n\\nFeatures:\\n')\n  .replace(/Highlights:\\s*/i, '\\n\\nHighlights:\\n')\n  .replace(/Amenities:\\s*/i, '\\n\\nAmenities:\\n');\n\n// Remove marketing/contact fluff at the end\ndescription = description\n  .replace(/Contact now.*$/is, '')\n  .replace(/For more information.*$/is, '')\n  .replace(/Kindly call.*$/is, '')\n  .replace(/Call us.*$/is, '')\n  .replace(/Please call.*$/is, '')\n  .replace(/For enquir.*$/is, '')\n  .replace(/For inspection.*$/is, '');\n\n// Final cleanup\ndescription = description\n  .replace(/\\n{3,}/g, '\\n\\n')\n  .replace(/[ \\t]+/g, ' ')\n  .trim();\n\nif (description.length > 2000) description = description.substring(0, 2000) + '...';\n\n// ---- AGENT CONTACTS ----\nconst phone = scrape(/href=\"tel:([^\"]+)\"/);\nconst waNum = scrape(/phone=(\\d+)/);\nconst email = scrape(/mailto:([^\"]+)\"/);\n\nreturn [{\n  json: {\n    title: listing.title || '',\n    price_raw: listing.price_raw || '',\n    price_numeric: listing.price_numeric || 0,\n    location: listing.location || '',\n    url: listing.url || '',\n    bedrooms: listing.bedrooms || 0,\n    property_type: listing.property_type || '',\n    agent_phone: phone,\n    agent_whatsapp: waNum ? '+' + waNum : '',\n    agent_email: email || 'Judedivine68@gmail.com',\n    description: description\n  }\n}];"
      },
