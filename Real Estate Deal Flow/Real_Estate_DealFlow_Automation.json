    {
      "parameters": {
        "jsCode": "const original = $('Scrape Agent Contacts').first().json;\nconst aiOutput = $input.first().json;\n\nlet aiResult = {};\ntry {\n  const text = aiOutput.output || aiOutput.text || '{}';\n  const jsonMatch = text.match(/\\{[\\s\\S]*\\}/);\n  aiResult = jsonMatch ? JSON.parse(jsonMatch[0]) : {};\n} catch (e) {\n  aiResult = { score: 0, recommendation: 'SKIP', evaluation: 'Failed to parse AI response' };\n}\n\nreturn [{\n  json: {\n    ...original,\n    ai_score: aiResult.score || 0,\n    ai_recommendation: aiResult.recommendation || 'SKIP',\n    ai_evaluation: aiResult.evaluation || 'No analysis'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3312,
