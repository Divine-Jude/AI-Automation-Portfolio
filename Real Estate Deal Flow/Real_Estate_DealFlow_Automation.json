{
  "name": "Real Estate Deal Flow Automation",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst properties = [];\n\nfor (const item of allItems) {\n  const html = item.json.data || '';\n\n  // Split HTML by each property-listing card\n  const cards = html.split(/class=\"property-listing\"/);\n  // Skip the first chunk (before the first card)\n  for (let c = 1; c < cards.length; c++) {\n    const card = cards[c];\n\n    // Title + URL: from .pl-title h3 > a\n    const titleMatch = card.match(/class=\"pl-title\"[\\s\\S]*?<h3[^>]*>\\s*<a[^>]*href=[\"']([^\"']+)[\"'][^>]*>([^<]+)<\\/a>/i);\n    const title = titleMatch ? titleMatch[2].trim() : '';\n    const urlPath = titleMatch ? titleMatch[1].trim() : '';\n\n    // Location: from .pl-title p (first <p> inside pl-title)\n    const locMatch = card.match(/class=\"pl-title\"[\\s\\S]*?<p[^>]*>([^<]+)<\\/p>/i);\n    const location = locMatch ? locMatch[1].trim() : '';\n\n    // Price: from .pl-price h3\n    const priceMatch = card.match(/class=\"pl-price\"[\\s\\S]*?<h3[^>]*>([\\s\\S]*?)<\\/h3>/i);\n    let priceText = priceMatch ? priceMatch[1].replace(/<[^>]+>/g, '').trim() : '';\n\n    // Clean price to numeric\n    const priceStr = priceText.replace(/[\\u20A6,\\s]/g, '');\n    const priceNumeric = parseInt(priceStr) || 0;\n\n    // Property type detection\n    const t = title.toLowerCase();\n    let propertyType = 'Other';\n    if (t.includes('detached') && !t.includes('semi')) propertyType = 'Detached Duplex';\n    else if (t.includes('semi')) propertyType = 'Semi-Detached Duplex';\n    else if (t.includes('terrace')) propertyType = 'Terrace';\n    else if (t.includes('flat') || t.includes('apartment')) propertyType = 'Flat/Apartment';\n    else if (t.includes('land') || t.includes('plot')) propertyType = 'Land/Plot';\n    else if (t.includes('commercial')) propertyType = 'Commercial';\n\n    // Bedrooms from title\n    const bedMatch = title.match(/(\\d+)\\s*(?:bed(?:room)?s?|beds?)\\b/i)\n               || title.match(/\\b(one|two|three|four|five|six)\\s*(?:bed(?:room)?s?)\\b/i);\n\nlet bedrooms = 0;\nif (bedMatch) {\n  const wordToNum = { one: 1, two: 2, three: 3, four: 4, five: 5, six: 6 };\n  const val = bedMatch[1].toLowerCase();\n  bedrooms = parseInt(val) || wordToNum[val] || 0;\n}\n\n    if (title) {\n      properties.push({\n        json: {\n          title,\n          price_raw: priceText,\n          price_numeric: priceNumeric,\n          location,\n          url: urlPath ? 'https://www.propertypro.ng' + urlPath : null,\n          bedrooms,\n          property_type: propertyType\n        }\n      });\n    }\n  }\n}\n\nreturn properties;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1840,
        2048
      ],
      "id": "7ab76399-4e31-4348-8c5c-fc533162cace",
      "name": "Extract & Normalize Listings"
    },
    {
      "parameters": {
        "jsCode": "const totalPages = 5;\nconst pages = [];\nfor (let i = 1; i <= totalPages; i++) {\n  const url = i === 1 ? 'https://www.propertypro.ng/property-for-sale/in/lagos' : 'https://www.propertypro.ng/property-for-sale/in/lagos?page=' + i;\n  pages.push({ json: { pageUrl: url } });\n}\nreturn pages;"
      },
      "type": "n8n-nodes-base.code",
